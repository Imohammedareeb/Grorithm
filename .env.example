# ── Contact form delivery (pick ONE; checked in this order) ──────────────────
#
# 1) Web3Forms — easiest, no backend. The form emails grorithm@gmail.com directly.
#    Get a free access key at https://web3forms.com (enter grorithm@gmail.com),
#    then paste it here:
VITE_WEB3FORMS_KEY=

# 2) Or a dedicated Node API service that writes to MongoDB Atlas (see README).
VITE_ENQUIRY_ENDPOINT=

# With neither set, the form falls back to opening the visitor's mail client
# (mailto:grorithm@gmail.com) — it works, but nothing is captured automatically.
